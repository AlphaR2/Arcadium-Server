# ─── Server
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# ─── Solana 
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret_here
ESCROW_PROGRAM_ID=YourEscrowProgramPublicKeyHere
USDC_MINT=
TREASURY_TOKEN_ACCOUNT=YourTreasuryTokenAccountAddressHere
AUTHORITY_PRIVATE_KEY=[]

# ─── Supabase (database + file storage)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Upstash Redis 
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
# TCP connection 
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) 
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# ─── Pinata (IPFS for agent 8004 NFT metadata)
PINATA_JWT=your_pinata_jwt_here

# ─── Telegram Bot (agent dispatch via Telegram — optional)
# Create a bot via @BotFather → copy the token here
# Leave blank to disable Telegram dispatch (webhook/polling still works)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Random secret used to verify incoming Telegram webhook requests
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_here
